RewriteEngine on
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [NC,L]

RewriteBase /
RewriteRule ^project1/(.*)$ /$1 [L,NC,R]
RewriteRule ^project2/(.*)$ /$1 [L,NC,R]
RewriteRule ^project3/(.*)$ /$1 [L,NC,R]
RewriteRule ^project4/(.*)$ /$1 [L,NC,R]
RewriteRule ^project5/(.*)$ /$1 [L,NC,R]